{
  "name": "qa-lab-automation",
  "version": "0.1.0",
  "private": true,
  "description": "E2E automation suite for the QA-Lab Android app (WebdriverIO + TypeScript + Appium 2 + Cucumber).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test:android": "wdio run wdio.android.conf.ts",
    "test:android:smoke": "wdio run wdio.android.conf.ts --cucumberOpts.tags=\"@smoke and @android\"",
    "test:android:regression": "wdio run wdio.android.conf.ts --cucumberOpts.tags=\"@regression and @android\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "appium": "appium --base-path=/wd/hub --log-level=info",
    "allure:report": "allure generate test-results/allure-results -o test-results/allure-report --clean && allure open test-results/allure-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/appium-service": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/cucumber-framework": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^8.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "expect-webdriverio": "^5.6.9",
    "prettier": "^3.9.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webdriverio": "^9.29.1"
  }
}
